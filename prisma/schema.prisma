generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum SubscriptionPlan {
  NONE
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  PAST_DUE
  CANCELED
}

enum PayoutStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

// --------------------------------------
// NEXTAUTH STANDARD MODELS
// --------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --------------------------------------
// PLATFORM CORE MODELS
// --------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // For credentials login
  role          Role      @default(USER)
  
  // Subscription Data
  stripeCustomerId    String?            @unique
  subscriptionPlan    SubscriptionPlan   @default(NONE)
  subscriptionStatus  SubscriptionStatus @default(INACTIVE)
  subscriptionEndDate DateTime?

  // Charity Data
  selectedCharityId String?
  charityPercentage Float    @default(10.0)
  charity           Charity? @relation(fields: [selectedCharityId], references: [id])

  // Relations
  accounts      Account[]
  sessions      Session[]
  scores        Score[]
  winnings      Winning[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Golf Scores
model Score {
  id        String   @id @default(cuid())
  value     Int      // 1-45 Stableford
  date      DateTime
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

// Charities
model Charity {
  id          String   @id @default(cuid())
  name        String
  description String   @db.Text
  imageUrl    String?
  isFeatured  Boolean  @default(false)
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Draws / Lottery System
model Draw {
  id              String    @id @default(cuid())
  month           DateTime  // Identifies which month's draw this is
  isPublished     Boolean   @default(false)
  winningNumbers  Int[]     // Array of 5 numbers
  jackpotRollover Float     @default(0)
  
  winnings        Winning[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Winnings / Prize Claims
model Winning {
  id          String       @id @default(cuid())
  userId      String
  drawId      String
  matchCount  Int          // 3, 4, or 5
  prizeAmount Float
  status      PayoutStatus @default(PENDING)
  proofUrl    String?      // Screenshot of scores

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  draw        Draw         @relation(fields: [drawId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}